{
  "name": "@lynx-extensions/xelement-input",
  "version": "0.0.1",
  "description": "Lynx XElement input and textarea NativeUI extension for Sparkling autolink.",
  "android": {
    "packageName": "com.lynx.xelement",
    "buildGradle": "android/build.gradle.kts",
    "elements": [
      {
        "name": "input",
        "className": "com.lynx.xelement.LynxUIInputAutoRegistry"
      },
      {
        "name": "textarea",
        "className": "com.lynx.xelement.LynxUITextAreaAutoRegistry"
      }
    ]
  },
  "ios": {
    "podspecPath": "ios/LynxXElementInput.podspec",
    "moduleName": "LynxXElementInput",
    "importName": "LynxXElementInput",
    "elements": [
      {
        "name": "input",
        "className": "LynxUIInputAutoRegistry"
      },
      {
        "name": "textarea",
        "className": "LynxUITextAreaAutoRegistry"
      }
    ]
  }
}

